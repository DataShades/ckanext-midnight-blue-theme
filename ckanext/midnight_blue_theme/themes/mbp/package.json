{
    "scripts": {
        "watch-scripts": "vite build -w",
        "build-scripts": "vite build",
        "typecheck-scripts": "tsc --noEmit",
        "watch-styles": "sass -Inode_modules -w assets/scss/main.scss assets/css/main.css --embed-sources",
        "compile-styles": "sass -Inode_modules assets/scss/main.scss assets/css/main.css --no-source-map; sass -Inode_modules assets/scss/main-rtl.scss assets/css/main-rtl.css --no-source-map --silence-deprecation color-functions --silence-deprecation global-builtin --silence-deprecation if-function"
    },
    "dependencies": {
        "@types/bootstrap": "^5.2.10",
        "@types/node": "^25.9.2",
        "bootstrap": "^5.3.3",
        "gulp": "^5.0.1",
        "gulp-clean-css": "^4.3.0",
        "gulp-if": "^3.0.0",
        "gulp-postcss": "^10.0.0",
        "gulp-sass": "^6.0.1",
        "gulp-sourcemaps": "^3.0.0",
        "gulp-touch-fd": "^2.0.0",
        "postcss": "^8.5.15",
        "postcss-sort-media-queries": "^6.6.2",
        "sass": "^1.99.0",
        "typescript": "^6.0.3"
    },
    "devDependencies": {
        "vite": "^8.0.16",
        "vite-plugin-checker": "^0.14.1"
    }
}
