{
    "exclude": ["node_modules"],
    "include": [
        "assets/src/*.ts"
    ],
    "compilerOptions": {
        "target": "es2020",
        "types": ["bootstrap", "node"],
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "strict": true,
        "moduleDetection": "force",
        "skipLibCheck": false
    }
}
